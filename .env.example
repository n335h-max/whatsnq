# AI Service Provider: "gemini", "openai", or "openrouter"
AI_PROVIDER=gemini

# Google Gemini API Key (Required if AI_PROVIDER=gemini)
# Get one from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Required if AI_PROVIDER=openai)
# Get one from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Google Sign-In OAuth Client ID
# Create one in Google Cloud Console and add your localhost/dev origins
GOOGLE_CLIENT_ID=your_google_client_id_here

# App URL used by Stripe redirects and portal return links
APP_BASE_URL=http://localhost:3000

# Stripe recurring billing
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PRICE_ID_BUSINESS=price_your_business_monthly_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Admin panel credentials
ADMIN_USER=admin
ADMIN_PASS=change_this_password
JWT_SECRET=replace_with_a_persistent_random_secret

# OpenRouter API Key (Required if AI_PROVIDER=openrouter)
# Get one from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nex-agi/nex-n2-pro:free
